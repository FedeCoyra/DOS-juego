@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50

package "RMI" {
    interface IObservableRemoto
    interface IControladorRemoto
    class ObservableRemoto
}

package "Modelo" {

    enum ColorCarta {
        ROJO
        AZUL
        VERDE
        AMARILLO
        SIN_COLOR
    }

    enum TipoCarta {
        NUMERICA
        COMODIN_NUMERO
        COMODIN_DOS
    }


    class Carta <<Serializable>> {
        - serialVersionUID : long = 1L
        - numero : int
        - color : ColorCarta
        - tipo : TipoCarta
        + Carta(int, ColorCarta, TipoCarta)
        + getNumero() : int
        + getColor() : ColorCarta
        + setColor(ColorCarta) : void
        + getTipo() : TipoCarta
        + esComodin() : boolean
        + esComodinNumero() : boolean
        + esComodinDos() : boolean
        + toString() : String
    }

    class Mazo <<Serializable>> {
        - serialVersionUID : long = 1L
        - cartas : List<Carta>
        + Mazo()
        - generarMazoCompleto() : void
        + barajar() : void
        + estaVacio() : boolean
        + robarCarta() : Carta
        ~ agregarCarta(Carta) : void
        + cantidadCartas() : int
    }

    class Mano <<Serializable>> {
        - serialVersionUID : long = 1L
        - cartas : List<Carta>
        + agregarCarta(Carta) : void
        + quitarCarta(int) : Carta
        + getCarta(int) : Carta
        + cantidadCartas() : int
    }

    class FilaCentral <<Serializable>> {
        - serialVersionUID : long = 1L
        - cartas : List<Carta>
        + agregarCarta(Carta) : void
        + quitarCarta(int) : Carta
        + getCarta(int) : Carta
        + cantidadCartas() : int
    }

    class Jugador <<Serializable>> {
        - serialVersionUID : long = 1L
        - nombre : String
        - mano : Mano
        - dijoDos : boolean
        - cartasPenalizacionPendientes : int
        + Jugador(String)
        + getNombre() : String
        + getMano() : Mano
        + isDijoDos() : boolean
        ~ setDijoDos(boolean) : void
        + getCartasPenalizacionPendientes() : int
        + sinCartas() : boolean
        + tieneDosCartas() : boolean
        + robarCarta(Carta) : void
        + jugarCarta(int) : Carta
        ~ agregarPenalizacion(int) : void
        ~ limpiarPenalizacion() : void
        + toString() : String
    }

    class ReglasDos {
        ~ puedeHacerJugadaSimple(Carta, int) : boolean
        ~ puedeHacerJugadaDoble(Carta, Carta, int) : boolean
        ~ hayBonoColorSimple(Carta, ColorCarta) : boolean
        ~ hayBonoColorDoble(Carta, Carta, ColorCarta) : boolean
        - coincideColor(ColorCarta, ColorCarta) : boolean
    }

    class GestorPenalizacionesDos {
        ~ acusarNoDijoDos(Jugador) : boolean
        ~ aplicarPenalizacionPendiente(Jugador, Mazo) : void
    }

    interface IJuegoDos {
        + iniciarNuevaPartida(int) : void
        + iniciarNuevaPartidaConNombres(List<String>) : void
        + getJugadores() : List<Jugador>
        + getFilaCentral() : FilaCentral
        + getJugadorActual() : Jugador
        + getIndiceJugadorActual() : int
        + getMazo() : Mazo
        + getGanador() : Jugador
        + hayGanador() : boolean
        + avanzarAlSiguienteJugador() : void
        + robarCartaJugadorActual() : Carta
        + asegurarFilaCentralMinima() : void
        + jugarCartaSimple(int, int, int, ColorCarta) : ResultadoJugadaSimple
        + jugarCartaDoble(int, int, int, int, ColorCarta) : ResultadoJugadaDoble
        + agregarCartaDeManoActualAFilaCentral(int) : void
        + hacerRobarUnaCartaATodosMenosActual() : void
        + jugadorActualPuedeDecirDos() : boolean
        + jugadorActualDiceDos() : void
        + aplicarPenalizacionNoDijoDos(int) : boolean
        + aplicarPenalizacionPendienteFinDeTurno(int) : void
        + exportarPartida() : PartidaGuardada
        + importarPartida(PartidaGuardada) : void
        + cerrarServidor() : void
    }

    class JuegoDos {
        - mazo : Mazo
        - descarte : List<Carta>
        - filaCentral : FilaCentral
        - jugadores : List<Jugador>
        - indiceJugadorActual : int
        - ganador : Jugador
        - reglas : ReglasDos
        - gestorPenalizaciones : GestorPenalizacionesDos
        - gestorPersistencia : GestorPersistencia
        + JuegoDos()
        - reciclarDescarteSiEsNecesario() : void
        - robarCarta(Jugador) : void
        - ponerEnDescarte(Carta) : void
        - actualizarEstadoDos(Jugador) : void
        - registrarVictoriaSiCorresponde(Jugador) : void
        + <<Implementación IJuegoDos>>
    }
}

package "Persistencia" {
    class GestorPersistencia {
        - CARPETA : String = "datos"
        - ARCHIVO_RANKING : String = "datos/ranking.dat"
        + GestorPersistencia()
        + guardarPartida(PartidaGuardada, String) : void
        + cargarPartida(String) : PartidaGuardada
        + cargarRanking() : List<RegistroRanking>
        + guardarRanking(List<RegistroRanking>) : void
        + registrarVictoria(String) : void
    }

    class PartidaGuardada <<Serializable>> {
        - serialVersionUID : long = 1L
        - mazo : Mazo
        - descarte : List<Carta>
        - filaCentral : FilaCentral
        - jugadores : List<Jugador>
        - indiceJugadorActual : int
        - ganador : Jugador
        + PartidaGuardada(Mazo, List<Carta>, FilaCentral, List<Jugador>, int, Jugador)
        + getMazo() : Mazo
        + getDescarte() : List<Carta>
        + getFilaCentral() : FilaCentral
        + getJugadores() : List<Jugador>
        + getIndiceJugadorActual() : int
        + getGanador() : Jugador
    }

    class RegistroRanking <<Serializable>> {
        - serialVersionUID : long = 1L
        - nombreJugador : String
        - victorias : int
        + RegistroRanking(String, int)
        + getNombreJugador() : String
        + getVictorias() : int
        + sumarVictoria() : void
        + toString() : String
    }
}

package "Vista" {
    interface VistaJuego {
        + mostrarMensaje(String) : void
        + mostrarEstado(List<Jugador>, FilaCentral, Jugador, Jugador, int) : void
        + pedirCantidadJugadores() : int
        + pedirNombresJugadores(int) : List<String>
        + preguntarSiCargarPartida() : boolean
        + pedirNombreArchivoPartida() : String
        + mostrarRankingTop5(List<RegistroRanking>) : void
        + pedirOpcionTurno(Jugador) : int
        + pedirIndiceCartaMano(Jugador) : int
        + pedirIndiceCartaCentral(FilaCentral) : int
        + pedirIndicesCartasDobles(Jugador) : int[]
        + pedirIndiceCartaBono(Jugador, int, int) : int
        + mostrarCartaRobada(Carta) : void
        + pedirIndiceJugadorParaPenalizar(List<Jugador>) : int
        + mostrarGanador(Jugador) : void
        + elegirColorParaComodinDos() : ColorCarta
        + elegirNumeroParaComodinNumero() : int
        + preguntarSiQuiereSeguirJugandoEnTurno() : boolean
        + preguntarSiQuiereIntentarJugadaDespuesDeRobar() : boolean
        + pedirIndiceCartaParaAgregarAFilaCentral(Jugador) : int
        + pedirOpcionPostRobo() : int
        + pedirOpcionFinDePartida() : int
    }

    class VistaConsola {
        - reader : BufferedReader
        + VistaConsola()
        - leerLinea() : String
        - leerEnteroEnRango(int, int) : int
        - leerSiNo() : boolean
        - mostrarManoConIndices(Jugador) : void
        - mostrarFilaCentralConIndices(FilaCentral) : void
        - describirCarta(Carta) : String
        + <<Implementación VistaJuego>>
    }

    class VistaSwing {
        - panelMesa : JPanel
        - panelCentro : JPanel
        - panelMano : JPanel
        + VistaSwing()
        - refrescarEstado(...) : void
        - callOnEdt(...) : T
        + <<Implementación VistaJuego>>
    }
}

package "Controlador" {
    class ControladorJuego {
        - juego : IJuegoDos
        - vista : VistaJuego
        - gestorPersistencia : GestorPersistencia
        + ControladorJuego(VistaJuego)
        + setModeloRemoto(T) : void
        + actualizar(IObservableRemoto, Object) : void
        + iniciar() : void
        - refrescarVista() : void
        - manejarTurno() : boolean
        - guardarPartida() : void
    }
}

package "Main" {
    class ClienteDosMain {
        + main(String[]) : void
    }
    class ServidorDosMain {
        + main(String[]) : void
    }
}

' RELACIONES
IObservableRemoto <|-- IJuegoDos
IJuegoDos <|.. JuegoDos
ObservableRemoto <|-- JuegoDos
IControladorRemoto <|.. ControladorJuego
VistaJuego <|.. VistaConsola
VistaJuego <|.. VistaSwing

JuegoDos *-- "1" Mazo
JuegoDos *-- "1" FilaCentral
JuegoDos *-- "*" Jugador
JuegoDos o-- "*" Carta : descarte
JuegoDos --> "1" ReglasDos
JuegoDos --> "1" GestorPenalizacionesDos
JuegoDos --> "1" GestorPersistencia

Jugador *-- "1" Mano
Mazo o-- "*" Carta
Mano o-- "*" Carta
FilaCentral o-- "*" Carta

Carta --> "1" ColorCarta
Carta --> "1" TipoCarta

ControladorJuego --> "1" IJuegoDos
ControladorJuego --> "1" VistaJuego
ControladorJuego --> "1" GestorPersistencia

GestorPersistencia ..> PartidaGuardada : lee/escribe
GestorPersistencia ..> RegistroRanking : lee/escribe

ClienteDosMain ..> ControladorJuego : instancia
ServidorDosMain ..> JuegoDos : instancia

@enduml