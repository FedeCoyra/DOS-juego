@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "RMI / Observer" {
    interface IObservableRemoto
    interface IControladorRemoto
    class ObservableRemoto
}

package "Modelo" {
    interface IJuegoDos {
        + iniciarNuevaPartida(int)
        + jugarCartaSimple(...) : ResultadoJugadaSimple
        + jugarCartaDoble(...) : ResultadoJugadaDoble
        + robarCartaJugadorActual() : Carta
        + jugadorActualDiceDos()
        + aplicarPenalizacionNoDijoDos(int) : boolean
        + exportarPartida() : PartidaGuardada
        + getJugadores() : List<Jugador>
    }

    class JuegoDos {
        - indiceJugadorActual : int
        - ganador : Jugador
        + iniciarNuevaPartida(int)
        + cerrarServidor()
    }

    class ReglasDos {
        + puedeHacerJugadaSimple(Carta, int) : boolean
        + puedeHacerJugadaDoble(Carta, Carta, int) : boolean
        + hayBonoColorSimple(...) : boolean
    }

    class GestorPenalizacionesDos {
        + acusarNoDijoDos(Jugador) : boolean
        + aplicarPenalizacionPendiente(Jugador, Mazo)
    }

    class Jugador {
        - nombre : String
        - dijoDos : boolean
        - cartasPenalizacionPendientes : int
        + robarCarta(Carta)
        + jugarCarta(int) : Carta
        + tieneDosCartas() : boolean
    }

    class Mazo {
        + barajar()
        + robarCarta() : Carta
    }

    class Mano {
        + agregarCarta(Carta)
        + quitarCarta(int) : Carta
    }

    class FilaCentral {
        + agregarCarta(Carta)
        + quitarCarta(int) : Carta
    }

    class Carta {
        - numero : int
        + esComodinNumero() : boolean
        + esComodinDos() : boolean
    }

    enum ColorCarta {
        ROJO
        AZUL
        VERDE
        AMARILLO
        SIN_COLOR
    }

    enum TipoCarta {
        NUMERICA
        COMODIN_NUMERO
        COMODIN_DOS
    }

    enum EventoJuego {
        PARTIDA_INICIADA
        TURNO_CAMBIADO
        JUGADA_SIMPLE
        GANADOR_DEFINIDO
    }
}

package "Controlador" {
    class ControladorJuego {
        - indiceJugadorLocal : int
        - esHost : boolean
        - partidaTerminada : boolean
        + iniciar()
        + actualizar(IObservableRemoto, Object)
        - manejarTurno()
        - manejarJugada()
    }
}

package "Vista" {
    interface VistaJuego {
        + mostrarEstado(...)
        + pedirOpcionTurno(Jugador) : int
        + mostrarMensaje(String)
        + mostrarGanador(Jugador)
        + mostrarRankingTop5(List)
    }

    class VistaConsola {
        - reader : BufferedReader
        + mostrarEstado(...)
    }

    class VistaSwing {
        - panelMesa : JPanel
        - panelMano : JPanel
        + mostrarEstado(...)
    }
}

package "Persistencia" {
    class GestorPersistencia {
        + guardarPartida(PartidaGuardada, String)
        + cargarPartida(String) : PartidaGuardada
        + registrarVictoria(String)
        + cargarRanking() : List<RegistroRanking>
    }

    class PartidaGuardada <<Serializable>> {
        - indiceJugadorActual : int
    }

    class RegistroRanking <<Serializable>> {
        - nombreJugador : String
        - victorias : int
        + sumarVictoria()
    }
}

' ==========================================
' RELACIONES (Patrones y Arquitectura)
' ==========================================

' Herencia y Realización MVC / RMI
IObservableRemoto <|-- IJuegoDos
IJuegoDos <|.. JuegoDos
ObservableRemoto <|-- JuegoDos
IControladorRemoto <|.. ControladorJuego
VistaJuego <|.. VistaConsola
VistaJuego <|.. VistaSwing

' Relaciones Controlador
ControladorJuego --> "1" IJuegoDos : conoce modelo
ControladorJuego --> "1" VistaJuego : conoce vista
ControladorJuego --> "1" GestorPersistencia : usa

' Relaciones Modelo
JuegoDos *-- "1" Mazo : contiene
JuegoDos *-- "1" FilaCentral : contiene
JuegoDos *-- "*" Jugador : contiene
JuegoDos o-- "*" Carta : descarte
JuegoDos --> "1" ReglasDos : valida jugadas
JuegoDos --> "1" GestorPenalizacionesDos : gestiona castigos
JuegoDos --> "1" GestorPersistencia : guarda/carga

Jugador *-- "1" Mano : posee
Mazo o-- "*" Carta : agrupa
Mano o-- "*" Carta : agrupa
FilaCentral o-- "*" Carta : agrupa

Carta --> "1" ColorCarta : tiene
Carta --> "1" TipoCarta : tiene

' Relaciones Persistencia
GestorPersistencia ..> PartidaGuardada : crea/lee
GestorPersistencia ..> RegistroRanking : crea/lee
PartidaGuardada --> "1" Mazo : guarda estado
PartidaGuardada --> "1" FilaCentral : guarda estado
PartidaGuardada --> "*" Jugador : guarda estado

@enduml